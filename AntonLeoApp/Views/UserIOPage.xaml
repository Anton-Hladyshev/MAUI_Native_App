<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:AntonLeoApp.ViewModels"
             x:Class="AntonLeoApp.UserIOPage"
             Title="UserIO">
    <ContentPage.BindingContext>
        <viewModels:UserIOViewModel />
    </ContentPage.BindingContext>
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label Text="Add New Character" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" />

            <Label Text="Name:" FontAttributes="Bold" />
            <Entry Text="{Binding Name}" Placeholder="Enter character name" />

            <Label Text="Description:" FontAttributes="Bold" />
            <Editor Text="{Binding Description}" Placeholder="Enter character description" HeightRequest="100" />

            <Label Text="Photo:" FontAttributes="Bold" />
            <HorizontalStackLayout Spacing="10">
                <Button Text="Select Photo" Command="{Binding SelectPhotoCommand}"/>
                <Label Text="{Binding PhotoStatusText}" VerticalOptions="Center" />
            </HorizontalStackLayout>
            <Image Source="{Binding Image}"
                   HeightRequest="150" 
                   BackgroundColor="LightGray" 
                   Aspect="AspectFill" />

            <Button Text="Add Character" 
                    Command="{Binding AddCharacterCommand}"
                    Margin="0,20,0,0" 
                    FontAttributes="Bold" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
