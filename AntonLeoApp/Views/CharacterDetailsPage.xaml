<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:AntonLeoApp.ViewModels"
             x:DataType="viewmodels:CharacterDetailsViewModel"
             x:Class="AntonLeoApp.Views.CharacterDetailsPage"
             Title="Détails du personnage">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Image Source="{Binding Character.Image}" 
                   HeightRequest="300" 
                   Aspect="AspectFill" />
            
            <Label Text="{Binding Character.Name}" 
                   FontSize="24" 
                   FontAttributes="Bold" />
            
            <Label Text="{Binding Character.Description}" 
                   FontSize="16" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>