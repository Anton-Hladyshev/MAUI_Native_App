<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AntonLeoApp.MainPage"
             >
    
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            
            <Label Text="Bienvenue dans SW Explorer"
                   FontSize="28"
                   HorizontalOptions="Center"
                   FontAttributes="Bold" />
            
            <Label Text="Dans cette application tu peux explorer une galaxie lointaine très lointaine"
                   FontSize="16"
                   HorizontalOptions="Center" />
            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                <Image Source="galactic_republic.png"
                       WidthRequest="150"
                />
                <Image Source="galactic_republic.png"
                       WidthRequest="150"
                />
            </HorizontalStackLayout>
            
        </VerticalStackLayout>
        
    </ScrollView>

</ContentPage>
