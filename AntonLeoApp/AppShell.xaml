<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="AntonLeoApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:AntonLeoApp"
    Title="AntonLeoApp">

    <TabBar>
        <ShellContent
            Title="Home"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage" />

        <ShellContent
            Title="Characters"
            ContentTemplate="{DataTemplate local:CharactersPage}"
            Route="CharactersPage" />

        <ShellContent
            Title="UserIO"
            ContentTemplate="{DataTemplate local:UserIOPage}"
            Route="UserIOPage" />

        <ShellContent
            Title="Unknown"
            ContentTemplate="{DataTemplate local:UnknownPage}"
            Route="UnknownPage" />
    </TabBar>

</Shell>
